{
  "name": "forgetful-ui",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:build": "docker build -f docker/Dockerfile -t forgetful-ui:latest .",
    "docker:tag": "docker tag forgetful-ui:latest ghcr.io/riffi/forgetful-ui:latest && docker tag forgetful-ui:latest ghcr.io/riffi/forgetful-ui:v%npm_package_version%",
    "docker:tag:unix": "docker tag forgetful-ui:latest ghcr.io/riffi/forgetful-ui:latest && docker tag forgetful-ui:latest ghcr.io/riffi/forgetful-ui:v$npm_package_version",
    "docker:push": "docker push ghcr.io/riffi/forgetful-ui:latest && docker push ghcr.io/riffi/forgetful-ui:v%npm_package_version%",
    "docker:push:unix": "docker push ghcr.io/riffi/forgetful-ui:latest && docker push ghcr.io/riffi/forgetful-ui:v$npm_package_version",
    "release": "npm run build && npm run docker:build && npm run docker:tag && npm run docker:push",
    "release:unix": "npm run build && npm run docker:build && npm run docker:tag:unix && npm run docker:push:unix",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "dependencies": {
    "@mantine/core": "^7.14.3",
    "@mantine/hooks": "^7.14.3",
    "@tabler/icons-react": "^3.24.0",
    "@tanstack/react-query": "^5.62.3",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "d3-force": "^3.0.0",
    "highlight.js": "^11.11.1",
    "mantine-datatable": "^7.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.0",
    "react-router-dom": "^7.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1"
  }
}
